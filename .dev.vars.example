# Copy to .dev.vars for local development. Leave host values blank to use
# the current Worker origin, including workers.dev deployments.
CUBEFLARE_SECRET=

# Required for Sandbox SDK production backup and restore transport.
CLOUDFLARE_ACCOUNT_ID=
BACKUP_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional custom domains.
PUBLIC_BASE_HOST=
PREVIEW_HOSTNAME=
PREVIEW_DNS_READY=false

# Optional: required only for R2 jurisdiction-specific buckets.
BACKUP_BUCKET_ENDPOINT=
